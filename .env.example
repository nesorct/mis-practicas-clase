# ============================================================================
# CONFIGURACIÓN N8N + CLAUDE API
# Copia este archivo a .env y rellena los valores
# ============================================================================

# ----------------------------------------------------------------------------
# SEGURIDAD - OBLIGATORIO
# ----------------------------------------------------------------------------

# Clave de encriptación de n8n (genera una: openssl rand -hex 32)
# IMPORTANTE: Guarda esta clave en un lugar seguro. Si la pierdes,
# las credenciales almacenadas en n8n serán irrecuperables.
N8N_ENCRYPTION_KEY=cambia_esto_por_una_clave_segura_de_64_caracteres_hex

# Autenticación básica de n8n
N8N_BASIC_AUTH_ACTIVE=true
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=tu_contraseña_segura_aqui

# ----------------------------------------------------------------------------
# CONFIGURACIÓN DE n8n
# ----------------------------------------------------------------------------

# Dominio y URL (cambia si usas dominio propio)
N8N_HOST=localhost
N8N_PROTOCOL=http
WEBHOOK_URL=http://localhost:5678/

# Zona horaria
GENERIC_TIMEZONE=Europe/Madrid

# Limpieza de datos de ejecución (horas, por defecto 7 días = 168)
EXECUTIONS_DATA_MAX_AGE=168

# Telemetría (false = desactivada)
N8N_DIAGNOSTICS_ENABLED=false

# ----------------------------------------------------------------------------
# BASE DE DATOS - PostgreSQL
# ----------------------------------------------------------------------------

POSTGRES_USER=n8n
POSTGRES_PASSWORD=postgres_password_segura
POSTGRES_DB=n8n

# Nombre del volumen Docker (si ya tienes uno, pon su nombre aquí)
POSTGRES_VOLUME=postgres_data

# ----------------------------------------------------------------------------
# REDIS - Para modo cola
# ----------------------------------------------------------------------------

# Nombre del volumen Redis (si ya tienes uno)
REDIS_VOLUME=redis_data

# ----------------------------------------------------------------------------
# API KEYS - INTEGRACIONES
# ----------------------------------------------------------------------------

# Anthropic Claude API - OBTÉN LA TUYA EN: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-xxxxx

# OpenAI (opcional - para embeddings o GPT)
OPENAI_API_KEY=sk-xxxxx

# ----------------------------------------------------------------------------
# VOLÚMENES EXISTENTES (si tienes)
# ----------------------------------------------------------------------------

# Si ya tienes un volumen para n8n, pon su nombre aquí
# Ejemplo: n8n_data, mi_n8n_volumen, etc.
N8N_VOLUME=n8n_data

# Si ya tienes volúmenes para PostgreSQL y Redis, ponlos aquí
# POSTGRES_VOLUME=mi_postgres_volumen
# REDIS_VOLUME=mi_redis_volumen
